{
  "name": "halqa-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 4100",
    "build": "tsc -b && vite build",
    "preview": "vite preview --port 4100",
    "mobile:sync": "npm run build && cap sync",
    "mobile:android:add": "cap add android",
    "mobile:android:open": "npm run mobile:sync && cap open android",
    "mobile:ios:add": "cap add ios",
    "mobile:ios:open": "npm run mobile:sync && cap open ios"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "@tailwindcss/vite": "4.3.2",
    "lucide-react": "1.23.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "recharts": "3.9.2",
    "socket.io-client": "4.8.3",
    "tailwindcss": "4.3.2"
  },
  "devDependencies": {
    "@types/node": "22.15.30",
    "@types/react": "18.3.23",
    "@types/react-dom": "18.3.7",
    "@vitejs/plugin-react": "4.3.4",
    "typescript": "5.8.3",
    "vite": "6.4.3"
  }
}
